{
  "extends": "./tsconfig.json",
  "include": [
    "electron.vite.config.ts",
    "tailwind.config.ts",
    "src/main/**/*.ts",
    "src/preload/**/*.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "types": [
      "node"
    ],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
